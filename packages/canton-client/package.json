{
  "name": "@repo/canton-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./ledger-api": {
      "types": "./dist/ledger-api/index.d.ts",
      "import": "./dist/ledger-api/index.js"
    },
    "./token-standard": {
      "types": "./dist/token-standard/index.d.ts",
      "import": "./dist/token-standard/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./party": {
      "types": "./dist/party.d.ts",
      "import": "./dist/party.js"
    },
    "./balance": {
      "types": "./dist/balance.d.ts",
      "import": "./dist/balance.js"
    },
    "./transfer": {
      "types": "./dist/transfer.d.ts",
